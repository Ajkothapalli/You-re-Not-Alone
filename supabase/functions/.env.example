# Edge Function secrets — set via: supabase secrets set KEY=value
# These NEVER go in the client bundle or git history.

# Required before any confession can be submitted.
# Absent key → 503 block (never silent pass). See CLAUDE.md.
MODERATION_API_KEY=sk-...

# Used for text-embedding-3-small (1536d).
# Absent → mock embedding used (dev only; non-semantic matching).
EMBEDDING_API_KEY=sk-...

# HMAC secret for author_token derivation.
# author_token = HMAC-SHA256(account_id, AUTHOR_TOKEN_SECRET)
# Never stored in DB. Changing this rotates ALL author tokens.
AUTHOR_TOKEN_SECRET=change-me-to-a-long-random-string
