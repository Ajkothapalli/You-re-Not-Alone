# ============================================================
# You Are Not Alone — environment variables
#
# Copy this file to .env and fill in real values.
# .env is in .gitignore — never commit real values.
# ============================================================


# ── Client bundle (safe to expose — baked into the app at build time) ─────────
# Only these two vars belong in the Expo client. Nothing else.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: analytics ingest key (PostHog project API key, or your provider's key).
# When absent, analytics events are logged to console in dev and dropped in prod.
EXPO_PUBLIC_ANALYTICS_KEY=


# ── Edge Function secrets (set via: supabase secrets set KEY=value) ───────────
# These never appear in the client bundle. They live only in the Edge Function
# runtime. See the "Secrets" section in CLAUDE.md for the full location matrix.

# HMAC key for author_token derivation.
# Generate: openssl rand -hex 64
# Rotation requires re-hashing all existing tokens — treat as permanent.
AUTHOR_TOKEN_SECRET=

# OpenAI key scoped to the Moderation API (omni-moderation-latest).
# Must have: POST /v1/moderations
MODERATION_API_KEY=

# OpenAI key for the gpt-4o-mini crisis classifier.
# Can be the same key as MODERATION_API_KEY if your org uses a single key.
# Must have: POST /v1/chat/completions
OPENAI_API_KEY=

# OpenAI key for text-embedding-3-small (dimensions=1536).
# Must have: POST /v1/embeddings
EMBEDDING_API_KEY=

# Set to "production" to enable hard blocks when API keys are absent.
# In development (any other value), missing keys log a warning and pass through
# so the UI can be tested without API credentials.
ENVIRONMENT=development

# Auto-injected by Supabase into the Edge Function runtime.
# DO NOT set this manually — it will be ignored or cause errors.
# SUPABASE_SERVICE_ROLE_KEY=(auto-injected)
